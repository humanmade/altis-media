{
	"name": "altis/media",
	"description": "Media module for Altis",
	"type": "library",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Human Made",
			"email": "hello@humanmade.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"darylldoyle/safe-svg": "2.3.3",
		"humanmade/tachyon-plugin": "~0.11.10",
		"humanmade/smart-media": "~0.5.12",
		"humanmade/aws-rekognition": "~0.1.10",
		"humanmade/rename-images-command": "^0.1.0",
		"humanmade/asset-manager-framework": "^0.13.6",
		"humanmade/amf-wordpress": "^0.3.0"
	},
	"autoload": {
		"classmap": [
			"inc/"
		],
		"files": [
			"inc/namespace.php",
			"inc/global_assets/namespace.php",
			"inc/private_media/namespace.php",
			"inc/private_media/visibility.php",
			"inc/private_media/content_parser.php",
			"inc/private_media/post_lifecycle.php",
			"inc/private_media/sanitisation.php",
			"inc/private_media/signed_urls.php",
			"inc/private_media/ui.php",
			"inc/private_media/site_icon.php",
			"inc/private_media/query_compat.php",
			"inc/private_media/cli.php"
		]
	},
	"extra": {
		"altis": {
			"install-overrides": [
				"darylldoyle/safe-svg",
				"humanmade/tachyon-plugin",
				"humanmade/smart-media",
				"humanmade/aws-rekognition",
				"humanmade/asset-manager-framework",
				"humanmade/amf-wordpress"
			]
		}
	}
}
